# Timing shift visualization: Boxplot of julian days
Visualizing the timing shift of "peak heat" is a way to examine the loss of thermal buffering in the watershed. Following wildfire, the removal of riparian canopy often causes the stream to track solar radiation more closely, frequently shifting the MWMT (Maximum Weekly Maximum Temperature) to an earlier date in the summer. In our case, it appears there was a differential shift in the tributaries relative to the mainstem - this is counter to my expectation based on wildfire burn intensity in the basin (in fact we may want to investigate how these two things are correlated)?
  
  ```{r timing shift plot, fig.height = 8, fig.width = 11}
# Calculate the Delta (Mean Change)
timing_deltas <- annual_metrics %>%
  filter(year != 2020) %>% #Excludes 2020 fire year
  group_by(site, period) %>%
  summarise(mean_doy = mean(MWMT_DOY, na.rm = TRUE), .groups = "drop") %>%
  pivot_wider(names_from = period, values_from = mean_doy) %>%
  mutate(
    delta = `Post-Fire` - `Pre-Fire`,
    label = paste0("Δ = ", round(delta, 1), " days"),
    y_pos = 155  # this controls y_position of the delta values
  )

# Update Factor Order
annual_metrics <- annual_metrics %>%
  mutate(site = factor(site, levels = c("SC1", "SC2", "BC", "MC", "SC3")))

# Plot with bottom-aligned Delta annotations
timing_plot <- ggplot(annual_metrics, aes(x = site, y = MWMT_DOY)) +
  # Boxplots and Jitter
  geom_boxplot(aes(fill = period), outlier.shape = NA, alpha = 0.7) +
  geom_jitter(aes(fill = period), position = position_dodge(width = 0.75), 
              alpha = 0.4, size = 2.5, shape = 21, color = "black") +
  
  # Add Delta Labels just above the Site Codes
  geom_text(data = timing_deltas, aes(x = site, y = y_pos, label = label),
            fontface = "bold", size = 5, color = "black") +
  
  # Scale and color formatting
  scale_fill_manual(values = c("Pre-Fire" = "#0072B2", "Post-Fire" = "#E69F00")) +
  scale_y_continuous(
    limits = c(152, 304), 
    breaks = c(152, 182, 213, 244, 274, 304),
    labels = c("June 1", "July 1", "Aug 1", "Sept 1", "Oct 1", "Oct 31")
  ) +
  
  # Labels and theme
  labs(
    title = "Figure 5. Shift in timing of peak thermal conditions (MWMT)",
    subtitle = "Delta (Δ) represents the mean change in days from Pre- to Post-Fire",
    y = "Date of peak temperature (MWMT)",
    x = "Site"
  ) +
  theme_classic() +
  theme(
    axis.text = element_text(size = 16, face = "bold", color = "black"),
