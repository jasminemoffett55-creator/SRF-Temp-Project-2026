# Correlation analysis: Decision support for potential site merging 
In this section we identify proximate sites (within the same stream reach or segment) that contain highly correlated temperature time series data. High thermal synchrony ($r > 0.90$) provides the scientific justification for creating reach-scale composites. Correlation analyses focuses on June 1 through October 31 period of interest, rather than the complete annual time series.

```{r Correlation analyses}
site_mat_data <- all_raw %>%
  group_by(ts_sync, site) %>%
  summarise(temp = mean(temperature, na.rm = TRUE), .groups = "drop") %>%
  pivot_wider(names_from = site, values_from = temp) %>%
  select(-ts_sync)

ggcorrplot(cor(site_mat_data, use = "pairwise.complete.obs"), 
           hc.order = TRUE, type = "lower", lab = TRUE, lab_size = 4,
           title = "Figure 1: Thermal synchrony matrix (Jun 1 - Oct 31)") + theme_classic()
```

# Extracting highly correlated site pairs: Candidate sites for data merging
The following table identifies all site pairs with a correlation coefficient ($r$) of 0.90 or higher. High values indicate that these sites are responding to the same thermal drivers.

```{r Identify high correlation}
# Extract the correlation matrix from the previous step
cor_results <- cor(site_mat_data, use = "pairwise.complete.obs")

# Convert the matrix into a long-form list for filtering
high_cor_table <- cor_results %>%
  as.data.frame() %>%
  rownames_to_column(var = "Site_A") %>%
  pivot_longer(cols = -Site_A, names_to = "Site_B", values_to = "r") %>%
  # Filter for strong correlation and remove self-correlations
  filter(r >= 0.90, Site_A != Site_B) %>%
  # Alphabetically sort names to identify and remove duplicates (A-B vs B-A)
  rowwise() %>%
  mutate(pair_id = paste(sort(c(Site_A, Site_B)), collapse = "-")) %>%
  ungroup() %>%
  distinct(pair_id, .keep_all = TRUE) %>%
  select(Site_A, Site_B, r) %>%
  arrange(desc(r))

# Display results using kable
if(nrow(high_cor_table) > 0) {
  high_cor_table %>%
    kable(digits = 3, 
          col.names = c("Primary Site", "Comparison Site", "Correlation (r)"),
          caption = "Table 2: Candidate site pairs for data merging (r >= 0.90)") %>%
    kable_styling(bootstrap_options = c("striped", "hover"), full_width = FALSE)
} else {
  cat("No site pairs met the r >= 0.90 threshold.")
}
```
# Perform site merging
Based on the information above, the logical candidates for data merging based on proximity are "Big Creek" and "BCEfish" (($r$) > 0.95) and "Puma" and "UpperScottCreek" (($r$) > 0.93). The next chunk of code performs these merges and also re-codes the site names for simplicity and aesthetics in all downstream analysis and data visualization chunks.

```{r site merging}
# Merging Function
process_pair <- function(data, s1, s2, new_name) {
  data %>%
    filter(site %in% c(s1, s2), is.na(bad_temperature) | bad_temperature == FALSE) %>%
    group_by(ts_sync, site) %>%
    summarise(temperature = mean(temperature, na.rm = TRUE), .groups = "drop") %>%
    pivot_wider(names_from = site, values_from = temperature) %>%
    rowwise() %>%
    mutate(temperature = mean(c_across(any_of(c(s1, s2))), na.rm = TRUE), site = new_name) %>%
    ungroup() %>% select(timestamp = ts_sync, site, temperature)
}

# EXECUTE SPECIFIC MERGES
# Based on correlation results (r >= 0.90), these are the only composite reaches we will generate
pair_a <- process_pair(all_raw, "BigCreek", "BCEfish", "Big Creek")
pair_b <- process_pair(all_raw, "Puma", "UpperScottCreek", "Upper Scott")

# Identify independent sites
merged_source_names <- c("BigCreek", "BCEfish", "Puma", "UpperScottCreek")

other_sites <- all_raw %>%
  filter(!(site %in% merged_source_names), is.na(bad_temperature) | bad_temperature == FALSE) %>%
  select(timestamp = ts_sync, site, temperature)

# Create master dataframe with re-coded site names
df_final <- bind_rows(pair_a, pair_b, other_sites) %>%
  mutate(
    date = as.Date(timestamp), 
    year = year(date), 
    doy = yday(date),
    # Explicitly define the three periods
    period = case_when(
      year < 2020 ~ "Pre-Fire",
      year == 2020 ~ "Fire Year",
      year > 2020 ~ "Post-Fire"
    ),
    period = factor(period, levels = c("Pre-Fire", "Fire Year", "Post-Fire")),
    site = case_match(site,
      "CombinedLagoonSites" ~ "SC1", #est
      "Gage"                ~ "SC2", #lsc
      "Big Creek"           ~ "BC", #bc
      "MillBridge"          ~ "MC", #MC
       "Upper Scott"         ~ "SC3", #USC
      "Lagoon"              ~ "LAG",
      "USEfish"             ~ "SUE",
      "Weir"                ~ "WEIR",
      .default = site
    )
  )
```




