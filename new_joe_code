# Threshold and cumulative stress plots
```{r threshold-and-cumulative-plots, fig.height = 11, fig.width = 15}
plot_data <- annual_metrics %>% 
  filter(year != 2020) %>% #Excludes 2020 fire year
  mutate(site = factor(site, levels = c("SC1", "SC2", "BC", "MC", "SC3")))

# Calculate Summary Stats
plot_stats <- plot_data %>%
  select(site, period, Days_16C, Days_18C, Days_20C, Consec_16C, Consec_18C, Consec_20C) %>%
  pivot_longer(cols = -c(site, period), names_to = "Metric", values_to = "Value") %>%
  group_by(site, period, Metric) %>%
  summarise(
    mean_val = mean(Value, na.rm = TRUE),
    se_val = sd(Value, na.rm = TRUE) / sqrt(n()),
    .groups = "drop"
  )

# Calculate max limits for standardization
max_total  <- max(plot_stats$mean_val[grepl("Days", plot_stats$Metric)] + 
                    plot_stats$se_val[grepl("Days", plot_stats$Metric)], na.rm = TRUE)
max_consec <- max(plot_stats$mean_val[grepl("Consec", plot_stats$Metric)] + 
                    plot_stats$se_val[grepl("Consec", plot_stats$Metric)], na.rm = TRUE)

# Helper Function with Integrated Spacing
create_sq_plot <- function(m_name, title_lab, p_tag, show_x = TRUE, show_y = TRUE, y_lab = "Days", y_lim) {
  y_breaks <- seq(0, ceiling(y_lim/25)*25, by = 25)
  y_upper  <- max(y_breaks)
  full_title <- paste0(p_tag, " ", title_lab)
  
  p <- ggplot(filter(plot_stats, Metric == m_name), aes(x = site, y = mean_val, fill = period)) +
    geom_bar(stat = "identity", position = position_dodge(width = 0.8), alpha = 0.9, color = "white") +
    geom_errorbar(aes(ymin = mean_val - se_val, ymax = mean_val + se_val), 
                  position = position_dodge(width = 0.8), width = 0.2) +
    scale_fill_manual(values = c("Pre-Fire" = "#0072B2", "Post-Fire" = "#E69F00")) +
    scale_y_continuous(limits = c(0, y_upper), breaks = y_breaks) +
    labs(title = full_title, y = y_lab, x = "Site") +
    theme_classic() +
    theme(
      axis.text = element_text(size = 16, face = "bold", color = "black"),
      axis.title = element_text(size = 16, face = "bold"),
      aspect.ratio = 1, 
      legend.position = "none",
      plot.title = element_text(size = 20, face = "bold", hjust = 0),
      # ADDING WHITE SPACE: Adjusting the plot margins
      plot.margin = margin(t = 15, r = 5, b = 15, l = 5) 
    )
  
  
  # X-axis logic
  if(!show_x) {
    p <- p + theme(axis.text.x = element_blank(), axis.ticks.x = element_blank())
  } else {
    p <- p + theme(axis.text.x = element_text(size = 16, face = "bold", color = "black"))
  }
  
  # Y-axis logic
  if(!show_y) {
    p <- p + theme(axis.title.y = element_blank(), axis.text.y = element_blank(), axis.ticks.y = element_blank())
  } else {
    p <- p + theme(axis.title.y = element_text(size = 18, face = "bold"),
                   axis.text.y = element_text(size = 16, face = "bold", color = "black"))
  }
  return(p)
}

# Generate Panels
pA <- create_sq_plot("Days_16C", "Total days > 16°C", "A)", FALSE, TRUE, "Mean total days annually", max_total) + theme(axis.title.x = element_blank())
pB <- create_sq_plot("Days_18C", "Total days > 18°C", "B)", FALSE, FALSE, "", max_total) + theme(axis.title.x = element_blank())

