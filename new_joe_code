# ESTABLISH GLOBAL "HELPER" FUNCTIONS FOR THE PIPELINE
safe_max <- function(x) {
  if(all(is.na(x)) || length(x) == 0) return(NA_real_)
  max(x, na.rm = TRUE)
}

max_consec <- function(temp_vector, threshold) {
  if(all(is.na(temp_vector))) return(NA_integer_)
  runs <- rle(temp_vector > threshold)
  if(any(runs$values == TRUE)) {
    return(max(runs$lengths[runs$values == TRUE]))
  } else {
    return(0)
  }
}
