# Data loading and cleaning

Here we derive the "site" name from the file name (everything left of the underscore) and standardize all data to an hourly "heartbeat" to account for potentially variable logging intervals at each temperature site. Specifically, if a logger recorded at 15 minute intervals and had multiple temperature measurements for a given hour, all valid records will be averaged to produce a single value. This step removes some of the noise in the data set and facilitates comparisons of thermal conditions across sites.

```{r Data loading and filename parsing}

file_list <- list.files("raw_data_files", full.names = TRUE, pattern = "\\.(csv|xlsx)$")

read_temp_file <- function(path) {
  fname <- basename(path)
  derived_site <- str_split_i(fname, "_", 1) # Extract site from file name, left of underscore
  
  ext <- tools::file_ext(path)
  dat <- if (ext == "csv") read_csv(path, show_col_types = FALSE) else read_excel(path)
  
  colnames(dat) <- tolower(colnames(dat))
  dat %>%
    rename(
      temperature = any_of(c("temperature", "temp", "temperature c", "temp_c")),
      timestamp = any_of(c("timestamp", "date_time", "datetime"))
    ) %>%
    mutate(
      site = derived_site, 
      temperature = as.numeric(temperature),
      timestamp = as.character(timestamp),
      bad_temperature = if("bad_temperature" %in% colnames(.)) bad_temperature else FALSE
    ) %>%
    select(timestamp, site, temperature, bad_temperature)
}

all_raw <- file_list %>% 
  map_df(~read_temp_file(.x)) %>%
  mutate(
    ts_sync = round_date(parse_date_time(timestamp, orders = c("ymd HMS", "mdy HMS", "ymd", "mdy")), "1 hour"),
    date = as.Date(ts_sync),
    year = year(date),
    month = month(date)
  ) %>%
  filter(month >= 6 & month <= 10) # Focus on the summer/fall salmonid index period, June 1 through October 31
```

