#only keep sites of interest 
sites_keep <- c("BC Efish", "Puma", "Weir", "MillBridge")


merge <- merge %>%
  filter(location %in% sites_keep) 

yr_2021 <- merge %>%
  filter(year(date) == 2021)

yr_2022 <- merge %>%
  filter(year(date) == 2022)


yr_2018 <- merge %>%
  filter(year(date) == 2018)

unique_names_2018 <- unique(yr_2018$site)

print(unique_names_2018)


#calc daily temp 
daily_temp18 <- yr_2018 %>%
  group_by(location, date) %>%  #group temp values by date 
  summarise(daily_mean_temp = mean(temperature, na.rm= TRUE)) %>% #calc max temp per day, ensure there are no NAs 
  ungroup()


gap_report <- daily_temp18 %>%
  # 1. Start with your specific locations (Optional)
  # filter(location %in% c("Big Creek", "Stone River")) %>% 
  
  filter(date >= as.Date("2018-06-01") & date <= as.Date("2018-10-31")) %>%
  
  group_by(location) %>%
  complete(date = seq.Date(as.Date("2018-06-01"), as.Date("2018-10-31"),
                           be = "day" )) %>%
                          
  
  # 3. Identify missing temperature values
  mutate(is_missing = is.na(daily_mean_temp)) %>%
  
  # 4. Create a unique ID for each continuous "run" of NAs
  mutate(gap_id = cumsum(is_missing != lag(is_missing, default = first(is_missing)))) %>%
  
  # 5. Filter for only the missing rows
  filter(is_missing) %>%
  
  # 6. CRITICAL: Group by BOTH location and gap_id
  group_by(location, gap_id) %>%
  summarize(
    gap_start = min(date),
    gap_end = max(date),
    days_missing = n(),
    .groups = "drop" # Keeps the output clean
  ) %>%
  
  # 7. Remove the helper ID
  dplyr::select(-gap_id)

print(gap_report)


