install.packages(c("tidyverse", "lubridate", "janitor", "ggplot2", "zoo", "slider"))


#call in packages
library(tidyverse)
library(lubridate)
library(janitor)
library(ggplot2)
library(zoo)
library(tidyr)
library(slider)

#read in csv, clean names, and set datetime with only valid datetime 
WQ2014 <- read_csv("C:/Users/eliza.pease/Desktop/temp_data/data/WQ2014_clean_FINAL.csv") %>% #read in csv
  clean_names() %>% #clean/standardize col names
  mutate( 
    location = str_trim(location), #get rid of spacing inconsistencies in location names
    date=as.Date(date, format = "%m/%d/%Y") # make sure date var is registering as date
  ) 


#only keep sites of interest 
sites_keep <- c("Big Creek", "Puma", "Upper Scott E-Fishing", "Weir", "Mill Creek")
WQ2014 <- WQ2014 %>%
  filter(location %in% sites_keep)  

#calc daily max temp per site 
daily_temp <- WQ2014 %>% #create daily max temp dataframe
  group_by(location, date) %>%  #group temp values by date 
  summarise(daily_max_temp= max(temperature_c, na.rm= TRUE), .groups = "drop") %>% #calc max temp per day, ensure there are no NAs 
  ungroup()





#calc 7d rolling avg of maxs 
daily_temp <- daily_temp %>%
  # Create a sequence from the min to max date FOR EACH site
  group_by(location) %>%
  reframe(
    date = seq(min(date), max(date), by = "day")
  ) %>%
  # Join the actual temp data back in
  left_join(daily_temp, by = c("location", "date")) %>%
  # Calculate rolling average within each site's specific range
  group_by(location) %>%
  arrange(date) %>%
  mutate(
    rolling_7d_mean = slide_index_dbl( #add col called rolling_7d_mean to daily_temp df
      .x = daily_max_temp,        # Column to calculate the average on
      .i = date,         # Date index column
      .f = mean,         # Function to apply (mean)
      .before = days(6), # Window size: 6 days before the current date
      .complete = FALSE, # Allow partial windows at the start
      .na_rm = TRUE      # Remove NA values within the window, allow to calc with less than 7 days 
    )
  ) %>%
  ungroup()


#create mwmt_by_site dataframe
MWMT_by_site <-daily_temp %>%
  group_by(location) %>%
  summarise(
    MWMT_val = max(rolling_7d_mean, na.rm=TRUE),
    .groups = "drop"
  )


#add MWMT_by_site to daily_temp for plotting 
daily_temp <- daily_temp %>%
  left_join(MWMT_by_site, by = "location") %>% #add MWAT_by_site to daily_temp
  mutate(
    facet_label = paste0(location, "\nMWMT = ", round(MWMT_val, 2),  " °C") #create new col called fact_label with site, location, line break
  )


#make sure its using the full range of values for each site 
date_check <- daily_temp %>%
  group_by(location) %>%
  summarise(
    first_real_temp = min(date[!is.na(daily_max_temp)]),
    last_real_temp = max(date[!is.na(daily_max_temp)]),
    last_valid_roll = max(date[!is.na(rolling_7d_mean)]), 
    .groups = "drop"
  )
    
print(date_check)

ggplot(daily_temp, aes(x= date)) + #sets up plot using daily_temp df with horiz axis being date
  geom_line(aes(y= daily_max_temp), color = "blue", alpha = 0.5) + #plot daily max temp which shows max temp reading of the day 
  geom_line(aes(y=rolling_7d_mean), color = "red", size = 1) +
  geom_hline(aes(yintercept = MWMT_val), color = "red", linetype= "dashed" ) + #plot MWMT as horiz dashed line 
  geom_text(
    data = MWMT_by_site, 
    aes(x =min(daily_temp$date), 
        y = MWMT_val, 
        label = paste0("MWMT = ", round(MWMT_val, 2), "°C " )),
    hjust =0, vjust= -0.5, 
    inherit.aes = FALSE
  )+ 
  facet_wrap(~location, scales = "free_x") + #plot 7day rolling avg, max value along red line = MWAT
  labs(
    title = "Daily Max Temperature, 7 Day Rolling Mean, and MWMT",
    x = "Date", 
    y = "Temperature (°C)"
  ) + 
  theme_bw()



    
