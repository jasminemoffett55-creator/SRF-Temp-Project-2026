weir_na_summary <- master2 %>%
  filter(site == "Weir") %>%
  filter(month(datetime) %in% 6:10) %>%   # June–October
  group_by(year) %>%
  summarise(
    na_count = sum(is.na(temperature)),
    total_obs = n(),
    pct_na = na_count / total_obs * 100
  ) %>%
  ungroup()

