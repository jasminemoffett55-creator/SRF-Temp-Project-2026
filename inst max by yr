lagoon_na_summary <- master2 %>%
  filter(site == "Lagoon") %>%
  filter(month(datetime) %in% 6:10) %>%
  group_by(year) %>%
  summarise(
    na_count = sum(is.na(temperature)),
    total_obs = n(),
    .groups = "drop"
  ) %>%
  complete(year = full_seq(year, 1), fill = list(na_count = 0, total_obs = 0)) %>%
  mutate(
    pct_na = ifelse(total_obs == 0, 100, na_count / total_obs * 100)
  )
